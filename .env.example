# Trail Checker — environment configuration template.
#
# Copy to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
#
# Both docker-compose's env_file directive AND app.py's load_dotenv()
# read from .env, so the same file works for Docker-based and bare-metal
# local runs. The .env file is the SINGLE source of truth for secrets.

# Flask session signing key. REQUIRED outside debug/testing.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string

# Postgres connection URL. The default below matches docker-compose's
# `db` service and is auto-injected there, so this line only matters
# when running the app outside Docker.
# DATABASE_URL=postgresql://app:app@db:5432/app

# OpenWeather API key (geocoding + weather + air quality).
# Required for /api/conditions and /trail-checker/results.
OPENWEATHER_API_KEY=your-openweather-key-here

# GitHub OAuth app credentials (Week 7).
# Create the OAuth app at https://github.com/settings/developers.
# Callback URL must exactly match redirect_uri (include port if Cursor forwards
# to e.g. localhost:62489): https://localhost/auth/github/callback
# or https://localhost:62489/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
